# TicketScout — Cloudflare Pages redirects
#
# ROUTING ARCHITECTURE:
# - /concert/[slug]  → static file at concert/[slug].html  (no redirect needed)
# - /football/[slug] → static file at football/[slug].html (no redirect needed)
# - /theatre/[slug]  → static file at theatre/[slug].html  (no redirect needed)
# - /venue/[slug]    → static file at venue/[slug].html    (no redirect needed)
#
# football/index.html, theatre/index.html, concert/index.html now handle
# /football/, /theatre/, /concert/ landing pages directly.
# The old /football → /football.html rules are REMOVED because they caused
# ERR_TOO_MANY_REDIRECTS when stubs tried to fetch /football.html
#
# CRITICAL: Do NOT add catch-all redirects for category subpaths
# Do NOT add /football → /football.html (causes redirect loop with football/ directory)

/concerts  /concert.html   200
